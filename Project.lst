				; // ----------------------------------
				; // animator_play
				; //	Switches the currently active animation to the targetAnimID
				; // and displays the first frame of the animation in the SpriteComponent.
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 000000BE			animator_play PROC PUBLIC USES eax ebx ecx edx esi edi, targetAnimID : DWORD
					local pThis
 000000BE  55		   *	    push   ebp
 000000BF  8B EC	   *	    mov    ebp, esp
 000000C1  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 000000C4  50		   *	    push   eax
 000000C5  53		   *	    push   ebx
 000000C6  51		   *	    push   ecx
 000000C7  52		   *	    push   edx
 000000C8  56		   *	    push   esi
 000000C9  57		   *	    push   edi
 000000CA  89 4D FC			mov pThis, ecx

 000000CD  8B 41 14			mov eax, (AnimatorComponent PTR [ecx]).curAnimIndex

					; // Load the current animation
 000000D0  8B 59 0C			mov ebx, (AnimatorComponent PTR [ecx]).pAnimations
 000000D3  6B C0 10			imul eax, SIZEOF Animation
 000000D6  8B 14 18			mov edx, (Animation PTR [ebx + eax]).animID

					.IF edx == targetAnimID
 000000D9  3B 55 08	   *	    cmp    edx, targetAnimID
 000000DC  75 02	   *	    jne    @C0001
 000000DE  EB 4D				jmp animator_play_exit ; // The current animation is the target animation, immediately exit
					.ENDIF
 000000E0		   *@C0001:

					; // Search for the targetAnimID in the pAnimations array
 000000E0  8B F1			mov esi, ecx
 000000E2  B9 00000000			mov ecx, 0 ; // i = 0
 000000E7  8B 7E 10			mov edi, (AnimatorComponent PTR [esi]).animCount

 000000EA			animator_play_search_loop:
					; // Check if we've gone through all animations and not found it
 000000EA  3B CF			cmp ecx, edi
 000000EC  7D 3F			jge animator_play_exit
				
					; // animations[i]
 000000EE  8B C1			mov eax, ecx
 000000F0  6B C0 10			imul eax, SIZEOF Animation
 000000F3  8B 14 18			mov edx, (Animation PTR [ebx + eax]).animID
				
					.IF edx == targetAnimID
 000000F6  3B 55 08	   *	    cmp    edx, targetAnimID
 000000F9  75 2F	   *	    jne    @C0003
 000000FB  89 4E 14				mov (AnimatorComponent PTR [esi]).curAnimIndex, ecx
 000000FE  C7 46 18				mov (AnimatorComponent PTR [esi]).curFrameIndex, 0
	   00000000
						
						; // Reset timeAccumulator to 0.0
 00000105  D9 EE				fldz
 00000107  D9 5E 1C				fstp (AnimatorComponent PTR [esi]).timeAccumulator
						
