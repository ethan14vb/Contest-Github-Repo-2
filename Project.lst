			      C INCLUDE component.inc
			      C ; // ==================================
			      C ; // component.inc
			      C ; // ----------------------------------
			      C ; //	Components are utility helpers to GameObjects that
			      C ; // allow for easy adding of features and a composition
			      C ; // structure for them (HasA vs IsA). 
			      C ; //	Some examples of components are SpriteComponents
			      C ; // that describe what a GameObject should look like or
			      C ; // TransformComponents that describe where a GameObject
			      C ; // is located spatially. 
			      C ; //	This is the generic component STRUCT that
			      C ; // all components inherit from.
			      C ; // ==================================
			      C 
			      C IFNDEF COMPONENT_INC
 = 00000001		      C COMPONENT_INC EQU 1
			      C 
