			      C 
			      C INCLUDE unordered_vector.inc
			      C ; // ==================================
			      C ; // unordered_vector.inc
			      C ; // ----------------------------------
			      C ; // unordered_vector are dynamic arrays of DWORDs
			      C ; // whose contents are not guaranteed to be in the same
			      C ; // order after a removal. They are typically used for 
			      C ; // pools of GameObject pointers whose order doesn't matter.
			      C ; // ==================================
			      C 
			      C IFNDEF UNORDERED_VECTOR_INC
			      C ENDIF
			      C 
			      C 
 00000008		      C Connection STRUCT
 00000000  00000000	      C     pInstance DWORD ?		; // This is either the "this" pointer of an instance or 0 for a global function
 00000004  00000000	      C     pFunction DWORD ?		; // The pointer to the function
			      C Connection ENDS
			      C 
 0000000C		      C Event STRUCT
 00000000  00000000	      C 	connections UnorderedVector <>
	   00000000
	   00000000
			      C Event ENDS
			      C 
			      C ; // Instance methods
			      C event_connect		PROTO		pInstance : DWORD, pFunction : DWORD
			      C event_disconnect	PROTO		pConnection : DWORD
