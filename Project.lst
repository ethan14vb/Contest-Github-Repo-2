				; // ----------------------------------
				; // animator_update
				; //	Updates the currently running animation based on deltaTime. This will
				; // update the current frame, alter the SpriteComponent's cell values,
				; // fire the animation ended event, and fire animation frame events.
				; //
				; //	If enough time has passed for multiple frames to pass, this function
				; // will skip frames to account for lag. Events from skipped frames will
				; // still fire.
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000137			animator_update PROC USES eax ebx ecx edx esi edi, deltaTime:REAL4
					local pThis
 00000137  55		   *	    push   ebp
 00000138  8B EC	   *	    mov    ebp, esp
 0000013A  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 0000013D  50		   *	    push   eax
 0000013E  53		   *	    push   ebx
 0000013F  51		   *	    push   ecx
 00000140  52		   *	    push   edx
 00000141  56		   *	    push   esi
 00000142  57		   *	    push   edi
 00000143  89 4D FC			mov pThis, ecx

					; // Update time accumulator
 00000146  D9 41 1C			fld (AnimatorComponent PTR [ecx]).timeAccumulator
 00000149  D8 45 08			fadd deltaTime
 0000014C  D9 59 1C			fstp (AnimatorComponent PTR [ecx]).timeAccumulator

 0000014F			animator_update_state:
					; // Evaluate the current animation playback state and whether to draw the current frame or transition to a new frame
 0000014F  8B 4D FC			mov ecx, pThis
