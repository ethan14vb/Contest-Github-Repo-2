 00000019  52		   *	    push   edx
 0000001A  57		   *	    push   edi
 0000001B  33 D2			xor edx, edx ; // edx = total
 0000001D  BB 00000001			mov ebx, 1 ; // ebx = multiplier
 00000022			parse_num_loop:
					; // Get the next character
 00000022  4F				dec edi
 00000023  0F B6 0F			movzx ecx, BYTE PTR [edi]

					; // Check if the character is a valid number
 00000026  80 F9 30			cmp cl, '0'
 00000029  7C 14			jl parse_EOL_number_exit
 0000002B  80 F9 39			cmp cl, '9'
 0000002E  7F 0F			jg parse_EOL_number_exit

					; // It's a valid digit, add the multiplied value to edx
 00000030  80 E9 30			sub cl, '0'
 00000033  8B C1			mov eax, ecx
 00000035  0F AF C3			imul eax, ebx
 00000038  03 D0			add edx, eax

					; // Increase the multiplier
 0000003A  6B DB 0A			imul ebx, 10
 0000003D  EB E3			jmp parse_num_loop

 0000003F			parse_EOL_number_exit:
 0000003F  8B C2			mov eax, edx
					ret
 00000041  5F		   *	    pop    edi
 00000042  5A		   *	    pop    edx
 00000043  5B		   *	    pop    ebx
 00000044  59		   *	    pop    ecx
 00000045  5E		   *	    pop    esi
 00000046  C3		   *	    ret    00000h
 00000047			parse_EOL_number ENDP

