 0000010A  8B 4E 08				mov ecx, (AnimatorComponent PTR [esi]).pSprite
 0000010D  8B 54 18 04				mov edx, (Animation PTR [ebx + eax]).pFrames
				
 00000111  8B 02				mov eax, (AnimationFrame PTR [edx]).cellX
 00000113  89 41 1C				mov (SpriteComponent PTR [ecx]).cellX, eax
 00000116  8B 42 04				mov eax, (AnimationFrame PTR [edx]).cellY
 00000119  89 41 20				mov (SpriteComponent PTR [ecx]).cellY, eax
 0000011C  8B 42 08				mov eax, (AnimationFrame PTR [edx]).cellW
 0000011F  89 41 24				mov (SpriteComponent PTR [ecx]).cellW, eax
 00000122  8B 42 0C				mov eax, (AnimationFrame PTR [edx]).cellH
 00000125  89 41 28				mov (SpriteComponent PTR [ecx]).cellH, eax
							
 00000128  EB 03				jmp animator_play_exit
					.ENDIF
 0000012A		   *@C0003:
				
 0000012A  41				inc ecx
 0000012B  EB BD			jmp animator_play_search_loop

 0000012D			animator_play_exit:
					ret
 0000012D  5F		   *	    pop    edi
 0000012E  5E		   *	    pop    esi
 0000012F  5A		   *	    pop    edx
 00000130  59		   *	    pop    ecx
 00000131  5B		   *	    pop    ebx
 00000132  58		   *	    pop    eax
