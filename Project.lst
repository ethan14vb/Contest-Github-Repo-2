			      C IFNDEF TEXTURE_INC
 = 00000001		      C TEXTURE_INC EQU 1
			      C 
 0000000C		      C Texture STRUCT
 00000000  00000000	      C 	h DWORD ?			; // The height of the texture
 00000004  00000000	      C 	w DWORD ?			; // The width of the texture
 00000008  00000000	      C 	pPixels DWORD ?		; // The pointer to the pixel data in RGBA (.PAM file format)
			      C Texture ENDS
			      C 
			      C ENDIF
