				; // ----------------------------------
				; // blendColor
				; // Private helper. Blends two colors together based on the alpha value of the foreground.
				; // ----------------------------------
 0000005F			blendColor PROC USES ebx ecx edx esi edi, fgColor : DWORD, bgColor : DWORD
				local finalColor : DWORD, fgAlpha : DWORD
 0000005F  55		   *	    push   ebp
 00000060  8B EC	   *	    mov    ebp, esp
 00000062  83 C4 F8	   *	    add    esp, 0FFFFFFF8h
 00000065  53		   *	    push   ebx
 00000066  51		   *	    push   ecx
 00000067  52		   *	    push   edx
 00000068  56		   *	    push   esi
 00000069  57		   *	    push   edi
 0000006A  8B 75 08			mov esi, fgColor
 0000006D  C1 EE 18			shr esi, 24 ; // Shift eax right 3 bytes to get alpha by itself

					; // If the fgColor is opaque, return the fgColor
					.IF eax == 0FFh
 00000070  3D 000000FF	   *	    cmp    eax, 0FFh
 00000075  75 08	   *	    jne    @C0001
 00000077  8B 45 08				mov eax, fgColor
 0000007A  E9 0000008E				jmp blendColor_exit
					.ENDIF
 0000007F		   *@C0001:

					; // If the fgColor is fully transparent, return the bgColor
					.IF eax == 0
 0000007F  0B C0	   *	    or	eax, eax
 00000081  75 08	   *	    jne    @C0003
 00000083  8B 45 0C				mov eax, bgColor
 00000086  E9 00000082				jmp blendColor_exit
					.ENDIF
 0000008B		   *@C0003:

					; // None of the jump conditions apply, so we must do the blending logic
					; // The formula is (fgColor * fgAlpha + bgColor * (255 - fgAlpha)) / 255
 0000008B  89 75 F8			mov fgAlpha, esi
 0000008E  BF 000000FF			mov edi, 255
 00000093  2B FE			sub edi, esi ; // 255 - fgAlpha

 00000095  BA 00000000			mov edx, 0

					; // Red
 0000009A  8B 45 08			mov eax, fgColor
 0000009D  25 000000FF			and eax, 0FFh
 000000A2  0F AF C6			imul eax, esi

 000000A5  8B 5D 0C			mov ebx, bgColor
 000000A8  81 E3 000000FF		and ebx, 0FFh
 000000AE  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 000000B1  03 C3			add eax, ebx
 000000B3  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 000000B6  0B D0			or edx, eax

					; // Green
 000000B8  8B 45 08			mov eax, fgColor
 000000BB  C1 E8 08			shr eax, 8 ; // Move 1 byte over
 000000BE  25 000000FF			and eax, 0FFh
 000000C3  0F AF C6			imul eax, esi

 000000C6  8B 5D 0C			mov ebx, bgColor
 000000C9  C1 EB 08			shr ebx, 8
 000000CC  81 E3 000000FF		and ebx, 0FFh
 000000D2  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 000000D5  03 C3			add eax, ebx
 000000D7  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 000000DA  C1 E0 08			shl eax, 8
 000000DD  0B D0			or edx, eax

					; // Blue
 000000DF  8B 45 08			mov eax, fgColor
 000000E2  C1 E8 10			shr eax, 16 ; // Move 2 byte over
 000000E5  25 000000FF			and eax, 0FFh
 000000EA  0F AF C6			imul eax, esi

 000000ED  8B 5D 0C			mov ebx, bgColor
 000000F0  C1 EB 10			shr ebx, 16
 000000F3  81 E3 000000FF		and ebx, 0FFh
 000000F9  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 000000FC  03 C3			add eax, ebx
 000000FE  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 00000101  C1 E0 10			shl eax, 16
 00000104  0B D0			or edx, eax

					; // Set alpha to FFh 
 00000106  B8 FF000000			mov eax, 0FF000000h
 0000010B  0B C2			or eax, edx
					
 0000010D			blendColor_exit:
					ret
