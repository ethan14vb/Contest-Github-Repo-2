				; // ==================================
				; // resource_manager.asm
				; // ----------------------------------
				; // Responsible for loading and unloading large
				; // assets such as textures.
				; // ==================================
				INCLUDE default_header.inc
			      C .386
			      C .model flat, stdcall
			      C option casemap : none
			      C .stack 4096
			      C OPTION PROC : PRIVATE
			      C 

 00000000			.code
				; // ----------------------------------
				; // load_texture
				; // Takes in the name of a file and then loads that file into memory.
				; //
				; // Returns:
				; //	A pointer to the texture created
				; // ----------------------------------
 00000000			load_texture PROC, pFilename:DWORD
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  8B 45 08			mov eax, pFilename
					ret
 00000006  C9		   *	    leave  
 00000007  C2 0004	   *	    ret    00004h
 0000000A			load_texture ENDP

				; // ----------------------------------
				; // unload_texture
				; // Takes a pointer to the texture to unload and destorys it.
				; // ----------------------------------
 0000000A			unload_texture PROC, pTexture:DWORD
 0000000A  55		   *	    push   ebp
 0000000B  8B EC	   *	    mov    ebp, esp
 0000000D  8B 45 08			mov eax, pTexture
					ret
 00000010  C9		   *	    leave  
 00000011  C2 0004	   *	    ret    00004h
 00000014			unload_texture ENDP

				END
