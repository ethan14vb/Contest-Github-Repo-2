			      C DEF_ENUM SPRITE_COMPONENT_ID
			      C DEF_ENUM TRANSFORM_COMPONENT_ID
			      C DEF_ENUM RENDERABLE_COMPONENT_ID
			      C DEF_ENUM TIMER_COMPONENT_ID
			      C DEF_ENUM TEXT_COMPONENT_ID
			      C DEF_ENUM ANIMATOR_COMPONENT_ID
			      C 
			      C ENDIF
			      C 
			      C 
