 00000000			.code
				; // ----------------------------------
				; // read_line
				; // Reads the next line in the input and fills a buffer
				; // This function is dangerous, please make sure there will always
				; // be a guaranteed CR-LF newline after the start index pointed to
				; // by esi.
				; //
				; // Input:
				; //	esi - Pointer to the start of the string
				; //	edi - Pointer to the start of the buffer
				; // Registered changed:
				; //	esi - Points at the next line
				; // ----------------------------------
 00000000			read_line PROC USES ebx ecx edx edi
 00000000  53		   *	    push   ebx
 00000001  51		   *	    push   ecx
 00000002  52		   *	    push   edx
 00000003  57		   *	    push   edi
 00000004			read_line_loop:
					; // Get the current character
 00000004  8A 06			mov al, BYTE PTR [esi]
 00000006  46				inc esi
					
					; // Check if we hit the CR in CRLF
 00000007  3C 0D			cmp al, CR
 00000009  74 05			je read_line_exit

					; // Store the current character into the destination buffer
 0000000B  88 07			mov BYTE PTR [edi], al
 0000000D  47				inc edi
 0000000E  EB F4			jmp read_line_loop

 00000010			read_line_exit:
					; // Move past the LF and null terminate the string
 00000010  46				inc esi
 00000011  C6 07 00			mov BYTE PTR [edi], 0
						
					ret
 00000014  5F		   *	    pop    edi
 00000015  5A		   *	    pop    edx
 00000016  59		   *	    pop    ecx
 00000017  5B		   *	    pop    ebx
 00000018  C3		   *	    ret    00000h
 00000019			read_line ENDP

