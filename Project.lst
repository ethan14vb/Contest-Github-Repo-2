				; // Line feed
 = 0000000A			LF = 10

 00000000			.code
				; // ----------------------------------
				; // read_line
				; // Reads the next line in the input and fills a buffer
				; // This function is dangerous, please make sure there will always
				; // be a guaranteed CR-LF newline after the start index pointed to
				; // by esi.
				; //
				; // Input:
				; //	esi - Pointer to the start of the string
				; //	edi - Pointer to the start of the buffer
				; // Registered changed:
				; //	esi - Points at the next line
				; //	edi - the end of the target buffer
				; // ----------------------------------
 00000000			read_line PROC USES ebx ecx edx
 00000000  53		   *	    push   ebx
 00000001  51		   *	    push   ecx
 00000002  52		   *	    push   edx
 00000003			read_line_loop:
					; // Get the current character
 00000003  8A 06			mov al, BYTE PTR [esi]
 00000005  46				inc esi
					
					; // Check if we hit the LF
 00000006  3C 0A			cmp al, LF
 00000008  74 05			je read_line_exit

					; // Store the current character into the destination buffer
 0000000A  88 07			mov BYTE PTR [edi], al
 0000000C  47				inc edi
 0000000D  EB F4			jmp read_line_loop

 0000000F			read_line_exit:
 0000000F  C6 07 00			mov BYTE PTR [edi], 0
						
					ret
 00000012  5A		   *	    pop    edx
 00000013  59		   *	    pop    ecx
 00000014  5B		   *	    pop    ebx
 00000015  C3		   *	    ret    00000h
 00000016			read_line ENDP

				; // ----------------------------------
				; // parse_EOL_number
				; // Returns the number at the end of a string.
				; //
				; // Input:
				; //	edi - Pointer to the null terminator of the string
				; // Returns:
				; //	The number value of the string at the end of the line
				; // ----------------------------------
 00000016			parse_EOL_number PROC USES esi ecx ebx edx edi
 00000016  56		   *	    push   esi
 00000017  51		   *	    push   ecx
 00000018  53		   *	    push   ebx
 00000019  52		   *	    push   edx
 0000001A  57		   *	    push   edi
 0000001B  33 D2			xor edx, edx ; // edx = total
 0000001D  BB 00000001			mov ebx, 1 ; // ebx = multiplier
 00000022			parse_num_loop:
					; // Get the next character
 00000022  4F				dec edi
 00000023  0F B6 0F			movzx ecx, BYTE PTR [edi]

					; // Check if the character is a valid number
 00000026  80 F9 30			cmp cl, '0'
 00000029  7C 14			jl parse_EOL_number_exit
 0000002B  80 F9 39			cmp cl, '9'
 0000002E  7F 0F			jg parse_EOL_number_exit

					; // It's a valid digit, add the multiplied value to edx
 00000030  80 E9 30			sub cl, '0'
 00000033  8B C1			mov eax, ecx
 00000035  0F AF C3			imul eax, ebx
 00000038  03 D0			add edx, eax

					; // Increase the multiplier
 0000003A  6B DB 0A			imul ebx, 10
 0000003D  EB E3			jmp parse_num_loop

 0000003F			parse_EOL_number_exit:
 0000003F  8B C2			mov eax, edx
					ret
 00000041  5F		   *	    pop    edi
 00000042  5A		   *	    pop    edx
 00000043  5B		   *	    pop    ebx
 00000044  59		   *	    pop    ecx
 00000045  5E		   *	    pop    esi
 00000046  C3		   *	    ret    00000h
 00000047			parse_EOL_number ENDP

