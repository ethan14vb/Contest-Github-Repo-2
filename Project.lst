 0000001C		      C RectComponent STRUCT
 00000000  00000000	      C 	baseRenderableComponent RenderableComponent <>
	   00000000
	   00000000
	   00000000
			      C 
 00000010  00000000	      C 	h DWORD ? ; // Height
 00000014  00000000	      C 	w DWORD ? ; // Width
			      C 
			      C 	; // Color (For future development, this should be an RGBA object)
			      C 	; // For simplicity reasons, it is 4 bytes for now. 
 00000018  00		      C 	r BYTE ?
 00000019  00		      C 	g BYTE ?
 0000001A  00		      C 	b BYTE ?
 0000001B  00		      C 	a BYTE ?
			      C RectComponent ENDS
			      C 
			      C ; // Constructor methods
			      C init_rect_component PROTO h: DWORD, w : DWORD, r : BYTE, g : BYTE, b : BYTE, a : BYTE
			      C new_rect_component PROTO h: DWORD, w: DWORD, r: BYTE, g: BYTE, b:  BYTE, a: BYTE
			      C free_rect_component PROTO
			      C 
			      C ENDIF
