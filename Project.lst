				; // ----------------------------------
				; // isKeyPressed
				; // Returns 1 if a key is currently pressed and 0 if a key
				; // is not currently pressed this frame.
				; // ----------------------------------
 00000097			isKeyPressed PROC PUBLIC USES ebx, vkCode: VK_CODE
 00000097  55		   *	    push   ebp
 00000098  8B EC	   *	    mov    ebp, esp
 0000009A  53		   *	    push   ebx
 0000009B  0F B6 5D 08			movzx ebx, vkCode
 0000009F  8A 83 00000000 R		mov al, curInputBuffer[ebx]
 000000A5  A8 80			test al, 80h ; // Test the high bit
 000000A7  74 07			jz keyNotPressed

					; // Key is pressed, return 1
 000000A9  B8 00000001			mov eax, 1
 000000AE  EB 05			jmp exitIsKeyPressed

 000000B0			keyNotPressed:
 000000B0  B8 00000000			mov eax, 0

 000000B5			exitIsKeyPressed:
					ret
 000000B5  5B		   *	    pop    ebx
 000000B6  C9		   *	    leave  
 000000B7  C2 0004	   *	    ret    00004h
 000000BA			isKeyPressed ENDP

				; // ----------------------------------
				; // isKeyJustPressed
				; // Returns 1 if a key is just pressed this frame and 0 if the key
				; // was not just pressed this frame.
				; // ----------------------------------
 000000BA			isKeyJustPressed PROC PUBLIC USES ebx, vkCode: VK_CODE
 000000BA  55		   *	    push   ebp
 000000BB  8B EC	   *	    mov    ebp, esp
 000000BD  53		   *	    push   ebx
 000000BE  8A 85 00000008 R		mov al, curInputBuffer[vkCode]
 000000C4  8A 9D 00000108 R		mov bl, prevInputBuffer[vkCode]

 000000CA  A8 80			test al, 80h ; // Test the high bit
 000000CC  74 0C			jz keyNotJustPressed
					
					; // Test if the key was also pressed last frame
 000000CE  F6 C3 80			test bl, 80h
 000000D1  75 07			jnz keyNotJustPressed

					; // Key was just pressed, return 1
 000000D3  B8 00000001			mov eax, 1
 000000D8  EB 05			jmp exitIsKeyJustPressed
						
 000000DA			keyNotJustPressed:
 000000DA  B8 00000000			mov eax, 0
 000000DF			exitIsKeyJustPressed:
					ret
 000000DF  5B		   *	    pop    ebx
 000000E0  C9		   *	    leave  
 000000E1  C2 0004	   *	    ret    00004h
 000000E4			isKeyJustPressed ENDP

