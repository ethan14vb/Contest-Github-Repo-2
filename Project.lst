 = 00000780		      C GAME_WIDTH = 1920
 = 00000438		      C GAME_HEIGHT = 1080
			      C 
 00000004		      C Pixel STRUCT
 00000000  00		      C     r BYTE ?
 00000001  00		      C     g BYTE ?
 00000002  00		      C     b BYTE ?
 00000003  00		      C     a BYTE ?
			      C Pixel ENDS
			      C 
			      C ENDIF
