 00000000			.code
				; // ----------------------------------
				; // writeByteInDecimal
				; // Writes a single byte's decimal representation using ASCII characters into a buffer. 
				; // 
				; // Parameters: 
				; //	AL - byte to print
				; //    EDI - pointer to the buffer to write text to
				; //
				; // Registers changed:
				; //	EDI - will be adjusted after prints. Does not add null terminator.
				; // ----------------------------------
 00000000			writeByteInDecimal PROC USES ebx
					; // divide by 100
 00000000  53		   *	    push   ebx
 00000001  32 E4			xor ah, ah
 00000003  B3 64			mov bl, 100
 00000005  F6 F3			div bl

 00000007  3C 00			cmp al, 0
 00000009  74 05			je print_tens

					; // print result (100s place)
 0000000B  04 30			add al, '0' ; // Add 0x30 to display correct ASCII number representation
 0000000D  88 07			mov [edi], al
 0000000F  47				inc edi

 00000010			print_tens:
 00000010  8A C4			mov al, ah
 00000012  32 E4			xor ah, ah

 00000014  B3 0A			mov bl, 10
 00000016  F6 F3			div bl

 00000018  3C 00			cmp al, 0
 0000001A  74 05			je print_ones

					; // print result (10s place)
 0000001C  04 30			add al, '0'
 0000001E  88 07			mov [edi], al
 00000020  47				inc edi

 00000021			print_ones:
					; // print remainder (1s place)
 00000021  80 C4 30			add ah, '0'
 00000024  88 27			mov[edi], ah	
 00000026  47				inc edi
					ret
 00000027  5B		   *	    pop    ebx
 00000028  C3		   *	    ret    00000h
 00000029			writeByteInDecimal ENDP

				; // ----------------------------------
				; // displayBuffer
				; // Renders an RGBA buffer to the screen using StretchDIBits
				; // Intended to be used for frame by frame animation. 
				; // 
				; // Parameters: 
				; //	pBuffer DWORD - pointer to the new frame buffer to render. MUST BE GAME_WIDTH * GAME_HEIGHT!!!
				; //
				; // ----------------------------------
 00000029			displayBuffer PROC PUBLIC USES esi edi ecx ebx, pBuffer:DWORD, hWnd:HWND
					LOCAL hdc:DWORD
 00000029  55		   *	    push   ebp
 0000002A  8B EC	   *	    mov    ebp, esp
 0000002C  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 0000002F  56		   *	    push   esi
 00000030  57		   *	    push   edi
 00000031  51		   *	    push   ecx
 00000032  53		   *	    push   ebx
					INVOKE GetDC, hWnd
 00000033  FF 75 0C	   *	    push   dword  ptr ss:[ebp]+00000000Ch
 00000036  E8 00000000 E   *	    call   GetDC
 0000003B  89 45 FC			mov hdc, eax

					INVOKE StretchDIBits,
						hdc,
						destX, destY,
						destW, destH,
						0, 0,
						GAME_WIDTH, GAME_HEIGHT,
						pBuffer,
						ADDR bmiHeader,
						0,
						SRCCOPY
 0000003E  68 00CC0020	   *	    push   +000CC0020h
 00000043  6A 00	   *	    push   +000000000h
 00000045  68 0000002C R   *	    push   OFFSET bmiHeader
 0000004A  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 0000004D  68 00000438	   *	    push   +000000438h
 00000052  68 00000780	   *	    push   +000000780h
 00000057  6A 00	   *	    push   +000000000h
 00000059  6A 00	   *	    push   +000000000h
 0000005B  FF 35 00000024 R *	    push   destH
 00000061  FF 35 00000020 R *	    push   destW
 00000067  FF 35 0000001C R *	    push   destY
 0000006D  FF 35 00000018 R *	    push   destX
 00000073  FF 75 FC	   *	    push   dword  ptr ss:[ebp]+0FFFFFFFCh
 00000076  E8 00000000 E   *	    call   StretchDIBits
					
					INVOKE ReleaseDC, hWnd, hdc
 0000007B  FF 75 FC	   *	    push   dword  ptr ss:[ebp]+0FFFFFFFCh
 0000007E  FF 75 0C	   *	    push   dword  ptr ss:[ebp]+00000000Ch
 00000081  E8 00000000 E   *	    call   ReleaseDC

 00000086  8B 45 08			mov eax, pBuffer
					ret
 00000089  5B		   *	    pop    ebx
 0000008A  59		   *	    pop    ecx
 0000008B  5F		   *	    pop    edi
 0000008C  5E		   *	    pop    esi
 0000008D  C9		   *	    leave  
 0000008E  C2 0008	   *	    ret    00008h
 00000091			displayBuffer ENDP

				; // ----------------------------------
				; // calculateAspectRatio
				; // Calculates the offset that the game window should be drawn at
				; // ----------------------------------
 00000091			calculateAspectRatio PROC USES ebx ecx edx esi
					local SCREEN_WIDTH : DWORD, SCREEN_HEIGHT : DWORD
 00000091  55		   *	    push   ebp
 00000092  8B EC	   *	    mov    ebp, esp
 00000094  83 C4 F8	   *	    add    esp, 0FFFFFFF8h
 00000097  53		   *	    push   ebx
 00000098  51		   *	    push   ecx
 00000099  52		   *	    push   edx
 0000009A  56		   *	    push   esi
					INVOKE GetSystemMetrics, SM_CXSCREEN
 0000009B  6A 00	   *	    push   +000000000h
 0000009D  E8 00000000 E   *	    call   GetSystemMetrics
 000000A2  89 45 FC			mov SCREEN_WIDTH, eax
					INVOKE GetSystemMetrics, SM_CYSCREEN
 000000A5  6A 01	   *	    push   +000000001h
 000000A7  E8 00000000 E   *	    call   GetSystemMetrics
 000000AC  89 45 F8			mov SCREEN_HEIGHT, eax

					; // Calculate SCREEN_WIDTH * GAME_HEIGHT
 000000AF  8B 45 FC			mov eax, SCREEN_WIDTH
 000000B2  BB 00000438			mov ebx, GAME_HEIGHT
 000000B7  F7 E3			mul ebx
 000000B9  8B F0			mov esi, eax

					; // Calculate SCREEN_HEIGHT * GAME_WIDTH
 000000BB  8B 45 F8			mov eax, SCREEN_HEIGHT
 000000BE  BB 00000780			mov ebx, GAME_WIDTH
 000000C3  F7 E3			mul ebx

					; // Determine if the screen should be displayed with letterboxing or pillarboxing.
					; // Letterboxing is when there are black bars on the top and bottom of the screen,
					; // and pillarboxing is when there are black bars on the right and left.
 000000C5  3B F0			cmp esi, eax
 000000C7  77 1B			ja pillarboxing

 000000C9			letterboxing:
 000000C9  8B 4D FC			mov ecx, SCREEN_WIDTH
 000000CC  89 0D 00000020 R		mov destW, ecx
					; //	destH = (ScreenWidth * GameHeight) / GameWidth
 000000D2  8B C6			mov eax, esi
 000000D4  33 D2			xor edx, edx
 000000D6  BB 00000780			mov ebx, GAME_WIDTH
 000000DB  F7 F3			div ebx
 000000DD  A3 00000024 R		mov destH, eax
 000000E2  EB 21			jmp calculateXYOffset
						
 000000E4			pillarboxing:
 000000E4  8B 4D F8			mov ecx, SCREEN_HEIGHT
 000000E7  89 0D 00000024 R		mov destH, ecx
					; //	destW = (ScreenHeight * GameWidth) / GameHeight
 000000ED  8B 45 F8			mov eax, SCREEN_HEIGHT
 000000F0  BB 00000780			mov ebx, GAME_WIDTH
 000000F5  F7 E3			mul ebx
 000000F7  33 D2			xor edx, edx
 000000F9  BB 00000438			mov ebx, GAME_HEIGHT
 000000FE  F7 F3			div ebx
 00000100  A3 00000020 R		mov destW, eax

 00000105			calculateXYOffset:
					; // destX = (ScreenWidth - destW) / 2
 00000105  8B 45 FC			mov eax, SCREEN_WIDTH
 00000108  2B 05 00000020 R		sub eax, destW
 0000010E  D1 E8			shr eax, 1
 00000110  A3 00000018 R		mov destX, eax

					; // destY = (ScreenHeight - destH) / 2
 00000115  8B 45 F8			mov eax, SCREEN_HEIGHT
 00000118  2B 05 00000024 R		sub eax, destH
 0000011E  D1 E8			shr eax, 1
 00000120  A3 0000001C R		mov destY, eax
					
					ret
 00000125  5E		   *	    pop    esi
 00000126  5A		   *	    pop    edx
 00000127  59		   *	    pop    ecx
 00000128  5B		   *	    pop    ebx
 00000129  C9		   *	    leave  
 0000012A  C3		   *	    ret    00000h
 0000012B			calculateAspectRatio ENDP

				; // ----------------------------------
				; // initializeRenderer
				; // Initializes the window for rendering by getting the screen resolution 
				; // and allocates space for the screen buffer
				; // ----------------------------------
 0000012B			initializeRenderer PROC PUBLIC USES eax
 0000012B  50		   *	    push   eax
					INVOKE calculateAspectRatio
 0000012C  E8 FFFFFF60	   *	    call   calculateAspectRatio

					; // Now initialize the screen buffer
 00000131  B8 00000780			mov eax, GAME_WIDTH
 00000136  69 C0 00000438	    imul eax, GAME_HEIGHT
 0000013C  C1 E0 02		    shl eax, 2

					INVOKE HeapAlloc, hHeap, HEAP_GENERATE_EXCEPTIONS OR HEAP_ZERO_MEMORY, eax
 0000013F  50		   *	    push   eax
 00000140  6A 0C	   *	    push   +00000000Ch
 00000142  FF 35 00000000 E *	    push   hHeap
 00000148  E8 00000000 E   *	    call   HeapAlloc
 0000014D  A3 00000028 R	    mov pScreenBuffer, eax

					ret
 00000152  58		   *	    pop    eax
 00000153  C3		   *	    ret    00000h
 00000154			initializeRenderer ENDP

				; // ----------------------------------
				; // blendColor
				; // Private helper. Blends two colors together based on the alpha value of the foreground.
				; // ----------------------------------
 00000154			blendColor PROC USES ebx ecx edx esi edi, fgColor : DWORD, bgColor : DWORD
				local finalColor : DWORD, fgAlpha : DWORD
 00000154  55		   *	    push   ebp
 00000155  8B EC	   *	    mov    ebp, esp
 00000157  83 C4 F8	   *	    add    esp, 0FFFFFFF8h
 0000015A  53		   *	    push   ebx
 0000015B  51		   *	    push   ecx
 0000015C  52		   *	    push   edx
 0000015D  56		   *	    push   esi
 0000015E  57		   *	    push   edi
 0000015F  8B 75 08			mov esi, fgColor
 00000162  C1 EE 18			shr esi, 24 ; // Shift eax right 3 bytes to get alpha by itself

					; // If the fgColor is opaque, return the fgColor
					.IF eax == 0FFh
 00000165  3D 000000FF	   *	    cmp    eax, 0FFh
 0000016A  75 08	   *	    jne    @C0001
 0000016C  8B 45 08				mov eax, fgColor
 0000016F  E9 0000008E				jmp blendColor_exit
					.ENDIF
 00000174		   *@C0001:

					; // If the fgColor is fully transparent, return the bgColor
					.IF eax == 0
 00000174  0B C0	   *	    or	eax, eax
 00000176  75 08	   *	    jne    @C0003
 00000178  8B 45 0C				mov eax, bgColor
 0000017B  E9 00000082				jmp blendColor_exit
					.ENDIF
 00000180		   *@C0003:

					; // None of the jump conditions apply, so we must do the blending logic
					; // The formula is (fgColor * fgAlpha + bgColor * (255 - fgAlpha)) / 255
 00000180  89 75 F8			mov fgAlpha, esi
 00000183  BF 000000FF			mov edi, 255
 00000188  2B FE			sub edi, esi ; // 255 - fgAlpha

 0000018A  BA 00000000			mov edx, 0

					; // Red
 0000018F  8B 45 08			mov eax, fgColor
 00000192  25 000000FF			and eax, 0FFh
 00000197  0F AF C6			imul eax, esi

 0000019A  8B 5D 0C			mov ebx, bgColor
 0000019D  81 E3 000000FF		and ebx, 0FFh
 000001A3  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 000001A6  03 C3			add eax, ebx
 000001A8  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 000001AB  0B D0			or edx, eax

					; // Green
 000001AD  8B 45 08			mov eax, fgColor
 000001B0  C1 E8 08			shr eax, 8 ; // Move 1 byte over
 000001B3  25 000000FF			and eax, 0FFh
 000001B8  0F AF C6			imul eax, esi

 000001BB  8B 5D 0C			mov ebx, bgColor
 000001BE  C1 EB 08			shr ebx, 8
 000001C1  81 E3 000000FF		and ebx, 0FFh
 000001C7  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 000001CA  03 C3			add eax, ebx
 000001CC  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 000001CF  C1 E0 08			shl eax, 8
 000001D2  0B D0			or edx, eax

					; // Blue
 000001D4  8B 45 08			mov eax, fgColor
 000001D7  C1 E8 10			shr eax, 16 ; // Move 2 byte over
 000001DA  25 000000FF			and eax, 0FFh
 000001DF  0F AF C6			imul eax, esi

 000001E2  8B 5D 0C			mov ebx, bgColor
 000001E5  C1 EB 10			shr ebx, 16
 000001E8  81 E3 000000FF		and ebx, 0FFh
 000001EE  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 000001F1  03 C3			add eax, ebx
 000001F3  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 000001F6  C1 E0 10			shl eax, 16
 000001F9  0B D0			or edx, eax

					; // Set alpha to FFh 
 000001FB  B8 FF000000			mov eax, 0FF000000h
 00000200  0B C2			or eax, edx
					
 00000202			blendColor_exit:
					ret
 00000202  5F		   *	    pop    edi
 00000203  5E		   *	    pop    esi
 00000204  5A		   *	    pop    edx
 00000205  59		   *	    pop    ecx
 00000206  5B		   *	    pop    ebx
 00000207  C9		   *	    leave  
 00000208  C2 0008	   *	    ret    00008h
 0000020B			blendColor ENDP
