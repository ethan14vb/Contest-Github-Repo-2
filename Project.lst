 = 0000000D			CR = 13 ; // Carriage return
 = 0000000A			LF = 10 ; // Line feed
 = 0000001B			ESCP = 1Bh ; // ESC character

				; // Renderer buffers
 00000018 00000000		destX DWORD ?
 0000001C 00000000		destY DWORD ?
 00000020 00000000		destW DWORD ?
 00000024 00000000		destH DWORD ?

 00000028  00000FA0 [		screenBuffer Pixel GAME_WIDTH * GAME_HEIGHT DUP(<0, 0, 0, 255>)
	    00 00 00 FF
	   ]

 00000000			.code
				; // ----------------------------------
				; // writeByteInDecimal
				; // Writes a single byte's decimal representation using ASCII characters into a buffer. 
				; // 
				; // Parameters: 
				; //	AL - byte to print
				; //    EDI - pointer to the buffer to write text to
				; //
				; // Registers changed:
				; //	EDI - will be adjusted after prints. Does not add null terminator.
				; // ----------------------------------
 00000000			writeByteInDecimal PROC USES ebx
					; // divide by 100
 00000000  53		   *	    push   ebx
 00000001  32 E4			xor ah, ah
 00000003  B3 64			mov bl, 100
 00000005  F6 F3			div bl

 00000007  3C 00			cmp al, 0
 00000009  74 05			je print_tens

					; // print result (100s place)
 0000000B  04 30			add al, '0' ; // Add 0x30 to display correct ASCII number representation
 0000000D  88 07			mov [edi], al
 0000000F  47				inc edi

 00000010			print_tens:
 00000010  8A C4			mov al, ah
 00000012  32 E4			xor ah, ah

 00000014  B3 0A			mov bl, 10
 00000016  F6 F3			div bl

 00000018  3C 00			cmp al, 0
 0000001A  74 05			je print_ones

					; // print result (10s place)
 0000001C  04 30			add al, '0'
 0000001E  88 07			mov [edi], al
 00000020  47				inc edi

 00000021			print_ones:
					; // print remainder (1s place)
 00000021  80 C4 30			add ah, '0'
 00000024  88 27			mov[edi], ah	
 00000026  47				inc edi
					ret
 00000027  5B		   *	    pop    ebx
 00000028  C3		   *	    ret    00000h
 00000029			writeByteInDecimal ENDP

				; // ----------------------------------
				; // displayBuffer
				; // Renders an RGBA buffer to the screen using StretchDIBits
				; // Intended to be used for frame by frame animation. 
				; // 
				; // Parameters: 
				; //	pBuffer DWORD - pointer to the new frame buffer to render. MUST BE GAME_WIDTH * GAME_HEIGHT!!!
				; //
				; // ----------------------------------
 00000029			displayBuffer PROC PUBLIC USES esi edi ecx ebx, pBuffer:DWORD
 00000029  55		   *	    push   ebp
 0000002A  8B EC	   *	    mov    ebp, esp
 0000002C  56		   *	    push   esi
 0000002D  57		   *	    push   edi
 0000002E  51		   *	    push   ecx
 0000002F  53		   *	    push   ebx
 00000030  8B 45 08			mov eax, pBuffer
					ret
 00000033  5B		   *	    pop    ebx
 00000034  59		   *	    pop    ecx
 00000035  5F		   *	    pop    edi
 00000036  5E		   *	    pop    esi
 00000037  C9		   *	    leave  
 00000038  C2 0004	   *	    ret    00004h
 0000003B			displayBuffer ENDP

				; // ----------------------------------
				; // calculateAspectRatio
				; // Calculates the offset that the game window should be drawn at
				; // ----------------------------------
 0000003B			calculateAspectRatio PROC USES ebx ecx edx esi
					local SCREEN_WIDTH : DWORD, SCREEN_HEIGHT : DWORD
 0000003B  55		   *	    push   ebp
 0000003C  8B EC	   *	    mov    ebp, esp
 0000003E  83 C4 F8	   *	    add    esp, 0FFFFFFF8h
 00000041  53		   *	    push   ebx
 00000042  51		   *	    push   ecx
 00000043  52		   *	    push   edx
 00000044  56		   *	    push   esi
					INVOKE GetSystemMetrics, SM_CXSCREEN
 00000045  6A 00	   *	    push   +000000000h
 00000047  E8 00000000 E   *	    call   GetSystemMetrics
 0000004C  89 45 FC			mov SCREEN_WIDTH, eax
					INVOKE GetSystemMetrics, SM_CYSCREEN
 0000004F  6A 01	   *	    push   +000000001h
 00000051  E8 00000000 E   *	    call   GetSystemMetrics
 00000056  89 45 F8			mov SCREEN_HEIGHT, eax

					; // Calculate SCREEN_WIDTH * GAME_HEIGHT
 00000059  8B 45 FC			mov eax, SCREEN_WIDTH
 0000005C  BB 00000032			mov ebx, GAME_HEIGHT
 00000061  F7 E3			mul ebx
 00000063  8B F0			mov esi, eax

					; // Calculate SCREEN_HEIGHT * GAME_WIDTH
 00000065  8B 45 F8			mov eax, SCREEN_HEIGHT
 00000068  BB 00000050			mov ebx, GAME_WIDTH
 0000006D  F7 E3			mul ebx

					; // Determine if the screen should be displayed with letterboxing or pillarboxing.
					; // Letterboxing is when there are black bars on the top and bottom of the screen,
					; // and pillarboxing is when there are black bars on the right and left.
 0000006F  3B F0			cmp esi, eax
 00000071  77 1B			ja pillarboxing

 00000073			letterboxing:
 00000073  8B 4D FC			mov ecx, SCREEN_WIDTH
 00000076  89 0D 00000020 R		mov destW, ecx
					; //	destH = (ScreenWidth * GameHeight) / GameWidth
 0000007C  8B C6			mov eax, esi
 0000007E  33 D2			xor edx, edx
 00000080  BB 00000050			mov ebx, GAME_WIDTH
 00000085  F7 F3			div ebx
 00000087  A3 00000024 R		mov destH, eax
 0000008C  EB 20			jmp calculateXYOffset
						
 0000008E			pillarboxing:
 0000008E  8B 4D F8			mov ecx, SCREEN_HEIGHT
 00000091  89 0D 00000024 R		mov destH, ecx
					; //	destW = (ScreenHeight * GameWidth) / GameHeight
 00000097  8B C2			mov eax, edx
 00000099  BB 00000050			mov ebx, GAME_WIDTH
 0000009E  F7 E3			mul ebx
 000000A0  33 D2			xor edx, edx
 000000A2  BB 00000032			mov ebx, GAME_HEIGHT
 000000A7  F7 F3			div ebx
 000000A9  A3 00000020 R		mov destW, eax

 000000AE			calculateXYOffset:
					; // destX = (ScreenWidth - destW) / 2
					; // destY = (ScreenHeight - destH) / 2
					
					ret
 000000AE  5E		   *	    pop    esi
 000000AF  5A		   *	    pop    edx
 000000B0  59		   *	    pop    ecx
 000000B1  5B		   *	    pop    ebx
 000000B2  C9		   *	    leave  
 000000B3  C3		   *	    ret    00000h
 000000B4			calculateAspectRatio ENDP

				; // ----------------------------------
				; // initializeRenderer
				; // Initializes the window for rendering by getting the screen resolution 
				; // ----------------------------------
 000000B4			initializeRenderer PROC PUBLIC USES eax
 000000B4  50		   *	    push   eax
					INVOKE calculateAspectRatio
 000000B5  E8 FFFFFF81	   *	    call   calculateAspectRatio

					ret
 000000BA  58		   *	    pop    eax
 000000BB  C3		   *	    ret    00000h
 000000BC			initializeRenderer ENDP

				; // ----------------------------------
				; // blendColor
				; // Private helper. Blends two colors together based on the alpha value of the foreground.
				; // ----------------------------------
 000000BC			blendColor PROC USES ebx ecx edx esi edi, fgColor : DWORD, bgColor : DWORD
				local finalColor : DWORD, fgAlpha : DWORD
 000000BC  55		   *	    push   ebp
 000000BD  8B EC	   *	    mov    ebp, esp
 000000BF  83 C4 F8	   *	    add    esp, 0FFFFFFF8h
 000000C2  53		   *	    push   ebx
 000000C3  51		   *	    push   ecx
 000000C4  52		   *	    push   edx
 000000C5  56		   *	    push   esi
 000000C6  57		   *	    push   edi
 000000C7  8B 75 08			mov esi, fgColor
 000000CA  C1 EE 18			shr esi, 24 ; // Shift eax right 3 bytes to get alpha by itself

					; // If the fgColor is opaque, return the fgColor
					.IF eax == 0FFh
 000000CD  3D 000000FF	   *	    cmp    eax, 0FFh
 000000D2  75 08	   *	    jne    @C0001
 000000D4  8B 45 08				mov eax, fgColor
 000000D7  E9 0000008E				jmp blendColor_exit
					.ENDIF
 000000DC		   *@C0001:

					; // If the fgColor is fully transparent, return the bgColor
					.IF eax == 0
 000000DC  0B C0	   *	    or	eax, eax
 000000DE  75 08	   *	    jne    @C0003
 000000E0  8B 45 0C				mov eax, bgColor
 000000E3  E9 00000082				jmp blendColor_exit
					.ENDIF
 000000E8		   *@C0003:

					; // None of the jump conditions apply, so we must do the blending logic
					; // The formula is (fgColor * fgAlpha + bgColor * (255 - fgAlpha)) / 255
 000000E8  89 75 F8			mov fgAlpha, esi
 000000EB  BF 000000FF			mov edi, 255
 000000F0  2B FE			sub edi, esi ; // 255 - fgAlpha

 000000F2  BA 00000000			mov edx, 0

					; // Red
 000000F7  8B 45 08			mov eax, fgColor
 000000FA  25 000000FF			and eax, 0FFh
 000000FF  0F AF C6			imul eax, esi

 00000102  8B 5D 0C			mov ebx, bgColor
 00000105  81 E3 000000FF		and ebx, 0FFh
 0000010B  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 0000010E  03 C3			add eax, ebx
 00000110  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 00000113  0B D0			or edx, eax

					; // Green
 00000115  8B 45 08			mov eax, fgColor
 00000118  C1 E8 08			shr eax, 8 ; // Move 1 byte over
 0000011B  25 000000FF			and eax, 0FFh
 00000120  0F AF C6			imul eax, esi

 00000123  8B 5D 0C			mov ebx, bgColor
 00000126  C1 EB 08			shr ebx, 8
 00000129  81 E3 000000FF		and ebx, 0FFh
 0000012F  0F AF DF			imul ebx, edi ; // Multiply the background color by 255 - fgAlpha

 00000132  03 C3			add eax, ebx
 00000134  C1 E8 08			shr eax, 8  ; // Divide by 256 instead of 255 for speed
 00000137  C1 E0 08			shl eax, 8
